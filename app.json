{
  "expo": {
    "name": "Nudgrr",
    "slug": "nudgrr",
    "version": "1.0.6",
    "orientation": "portrait",
    "scheme": "nudgrr",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#FFF9F0",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },
    "ios": {
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "supportsTablet": false,
      "bundleIdentifier": "com.noorlyfe.nudgrr",
      "buildNumber": "5",
      "infoPlist": {
        "CFBundleLocalizations": [
          "en",
          "zh-Hans",
          "zh-Hant",
          "da",
          "fr",
          "de",
          "ja",
          "es"
        ],
        "NSLocationWhenInUseUsageDescription": "This app does not use your location."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D3935"
      },
      "package": "com.noorlyfe.nudgrr",
      "versionCode": 7
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "expo-router",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9F0",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/SpaceMono_400Regular.ttf"
          ]
        }
      ],
      "expo-localization",
      "./plugins/withBootOverlay"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "fonts": [
      "./assets/fonts/SpaceMono_400Regular.ttf"
    ],
    "extra": {
      "oneSignalAppId": "f9df7667-c5ba-438a-bed7-66fd6dafa6ed",
      "router": {},
      "eas": {
        "projectId": "56a457d6-372e-4f5d-b1cf-1e9fa83961b3"
      }
    }
  }
}
